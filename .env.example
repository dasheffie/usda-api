# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# USDA FoodData Central API key — free at https://fdc.nal.usda.gov/api-key-signup.html
# The skills in claude/skills/*/SKILL.md reference this as ${USDA_FDC_API_KEY}
# in every curl example, so setting it via `export USDA_FDC_API_KEY=...` (or
# sourcing the .env file) is sufficient for every skill to run.
USDA_FDC_API_KEY=your_fdc_api_key_here
