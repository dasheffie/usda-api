# Ignore everything at repo root by default.
/*

# Top-level escape hatches.
!/.gitignore
!/README.md
!/LICENSE
!/claude/

# Inside each skill dir under claude/skills/, ignore everything
# except SKILL.md and the references/ folder (and its contents).
/claude/skills/*/**
!/claude/skills/*/SKILL.md
!/claude/skills/*/references/
!/claude/skills/*/references/**
