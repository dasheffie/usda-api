# Ignore everything at repo root by default.
/*

# Top-level escape hatches.
!/.gitignore
!/README.md
!/LICENSE
!/aggregate-trajectories.png
!/skills/
!/docs/

# Inside each skill dir under skills/, ignore everything
# except SKILL.md and the references/ folder (and its contents).
/skills/*/**
!/skills/*/SKILL.md
!/skills/*/references/
!/skills/*/references/**

# Under docs/, only docs/explainer/ is tracked; within it, only source
# text files (no rendered audio/video or tool state).
/docs/*
!/docs/explainer/
/docs/explainer/*
!/docs/explainer/.gitignore
!/docs/explainer/README.md
!/docs/explainer/DESIGN.md
!/docs/explainer/narration.txt
!/docs/explainer/hyperframes.json
!/docs/explainer/index.html
